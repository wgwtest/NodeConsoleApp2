{
  "$schemaVersion": "levels_v1_wrapped",
  "meta": {
    "title": "Level Pack v1",
    "notes": [
      "关卡数据统一封装为 { $schemaVersion, meta, enemyPools, levels }。",
      "level 只声明 wave -> enemyPoolId 的映射，不再在关卡节点内重复散落敌人模板列表。",
      "运行时由 DataManagerV2 在装载阶段把 enemyPoolId 展开为 waves[].enemies。"
    ],
    "fieldNotes": {
      "enemyPools": "敌人池字典：key 为 enemyPoolId，value 为可复用的敌人成员列表。",
      "enemyPools.*.members": "敌人池成员列表。每个成员至少需要 templateId，可选 position。",
      "levels": "关卡字典：key 为 levelId，value 为关卡定义。",
      "levels.*.flow": "关卡流转元数据。当前支持 kind=story|acceptance，以及 story 关卡的顺序字段 order。",
      "levels.*.waves[].enemyPoolId": "关卡波次绑定的敌人池 ID，由 DataManagerV2 负责映射到运行时 enemies 列表。",
      "levels.*.battlePlayerState": "进入战斗时注入的玩家运行时战斗态覆盖。当前支持 stats / bodyParts。",
      "levels.*.battlePlayerState.stats": "进入战斗时覆盖玩家运行时 stats，例如 hp / ap / speed。建议用于验收样本或特殊战斗规则。",
      "levels.*.battlePlayerState.bodyParts": "进入战斗时覆盖玩家运行时 bodyParts，可指定部位护甲当前值、上限和 weakness。",
      "levels.*.selectionMeta": "关卡选择卡片使用的轻量内容元数据。当前支持 difficultyLabel / enemyStyleTags / buildHint。",
      "levels.*.rewards": "关卡结算奖励。当前支持 exp / gold / kp，其中 kp 用于技能树知识点。"
    },
